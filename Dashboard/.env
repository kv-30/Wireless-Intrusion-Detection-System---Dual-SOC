# Backend
# Core logic removed for IP protection.
# Sensitive credentials and infrastructure details have been redacted.
# Replace these with your actual configuration values.

INFLUX_HOST=your-influx-host
INFLUX_PORT=8086
INFLUX_TOKEN=your-influx-token-here
INFLUX_ORG=your-org
INFLUX_BUCKET_BRONZE=bronze_layer
INFLUX_BUCKET_SILVER=silver_layer
INFLUX_BUCKET_GOLD=gold_layer

# ML Service
ML_API_URL=http://ml-service:5000/predict

# WebSocket
WS_HOST=0.0.0.0
WS_PORT=8000

# MQTT (ESP32)
MQTT_BROKER=your-broker-host
MQTT_PORT=1883
MQTT_TOPIC=system/data